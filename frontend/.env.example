# Dev: Vite dev server proxys to Spring Boot backend
# Prod: set Vercel env var VITE_API_BASE_URL to deployed backend URL (e.g. https://api.sindico.app)
VITE_API_BASE_URL=

# Alvo do proxy do Vite dev server (apenas desenvolvimento local).
# Se o backend Spring Boot estiver rodando localmente, use http://localhost:8080
# Se NAO estiver, aponte para o Railway:
# VITE_API_PROXY_TARGET=https://sindico-production-f0ac.up.railway.app
VITE_API_PROXY_TARGET=http://localhost:8080
