{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": "vite",
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "rewrites": [
          { "source": "/api/:path*", "destination": "https://sindico-production-f0ac.up.railway.app/api/:path*" },
          { "source": "/(.*)", "destination": "/index.html" }
    ]
}
