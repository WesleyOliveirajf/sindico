# Copie este arquivo para .env.vps e preencha os valores reais
# O arquivo .env.vps NÃO deve ser commitado no git

# Perfil Spring Boot a usar (vps para conectar na VPS, dev para H2 local)
SPRING_PROFILES_ACTIVE=vps

# Banco de dados (via SSH tunnel)
DB_USERNAME=sindico_user
DB_PASSWORD=TROQUE_PELA_SENHA_REAL

# Opcional: MCP Postgres no Cursor (.cursor/mcp.json) — use a mesma senha; o IDE pode expandir ${POSTGRES_PASSWORD} na URL
POSTGRES_PASSWORD=TROQUE_PELA_SENHA_REAL

# Usuário admin da aplicação
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE
