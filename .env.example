# Copie este arquivo para .env e preencha os valores reais
# O arquivo .env NÃO deve ser commitado no git

# Perfil Spring Boot ativo
SPRING_PROFILES_ACTIVE=supabase

# Supabase — conexão direta (porta 5432, não usar pooler transacional 6543 com Flyway)
# Projeto: https://supabase.com/dashboard/project/qxxqkkotrxkqzyupibkl
DB_URL=jdbc:postgresql://db.qxxqkkotrxkqzyupibkl.supabase.co:5432/postgres?sslmode=require
DB_USERNAME=postgres
DB_PASSWORD=TROQUE_PELA_SENHA_DO_DASHBOARD

# Origens permitidas no CORS (separadas por vírgula)
APP_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Usuário admin da aplicação
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE
